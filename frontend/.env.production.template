# Frontend Production Environment Template
# Copy file này thành .env.production trong thư mục frontend/

# Backend API URL (Update sau khi deploy backend)
VITE_API_URL=https://exam-online-backend.onrender.com

# ⚠️ HƯỚNG DẪN:
# 1. Copy file này: cp frontend/.env.production.template frontend/.env.production
# 2. Sau khi deploy backend lên Render.com
# 3. Copy URL của backend service
# 4. Mở frontend/.env.production và update VITE_API_URL
# 5. Commit và push:
#    git add frontend/.env.production
#    git commit -m "Update production API URL"
#    git push origin main
# 6. Frontend sẽ tự động redeploy với config mới
